# Google Gemini API Key
# Erhalte deinen API Key hier: https://aistudio.google.com/app/apikey
# 1. Gehe zu https://aistudio.google.com/app/apikey
# 2. Klicke auf "Create API Key"
# 3. Wähle ein bestehendes Google Cloud Projekt oder erstelle ein neues
# 4. Kopiere den generierten Key und füge ihn hier ein
GEMINI_API_KEY=your_gemini_api_key_here

# Admin Key für Admin-Portal Zugriff
# Setze einen sicheren, zufälligen String (mindestens 20 Zeichen)
# Beispiel: openssl rand -base64 32
VITE_ADMIN_KEY=your_secure_admin_key_here

# Firebase Configuration
# Erhalte diese Werte aus deiner Firebase Console:
# https://console.firebase.google.com/ → Projekt auswählen → Projekteinstellungen → Web-App
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
